코드의 row['이름']은 정확히 '이름'이라는 키를 찾지만, 실제 CSV 파일(image_c2e307.png)을 보면 이름 ,학번 ,중간... 처럼 쉼표 앞에 공백이 있습니다. 이 경우 파이썬은 키를 '이름 '(공백 포함)으로 인식하여 데이터를 매칭하지 못하고 에러가 발생해 루프를 건너뛰게 됩니다.

문제를 해결하고 과제 사양을 완벽히 충족하는 Q1 모범 답안을 정리해 드립니다.

Q1 (1점) - 학생 성적 보고서 생성기
(1) 코드
Python
import csv
import json
import logging

# (d) 로그 설정: level=logging.INFO [cite: 67]
logging.basicConfig(level=logging.INFO, format='%(levelname)s:%(message)s')

def make_report(csv_path: str, json_path: str) -> int:
    results = []
    processed_count = 0
    
    try:
        # (a) 읽기: UTF-8 인코딩 사용 [cite: 35, 7]
        with open(csv_path, "r", encoding="utf-8") as f:
            # 헤더와 데이터의 불필요한 공백을 제거하기 위해 skipinitialspace 설정
            reader = csv.DictReader(f, skipinitialspace=True)
            
            # [핵심 수정] 헤더 자체에 붙은 공백을 강제로 제거
            reader.fieldnames = [name.strip() for name in reader.fieldnames]
            
            for row in reader:
                try:
                    name = row['이름'].strip()
                    sid = row['학번'].strip()
                    
                    # 빈 칸이 있는지 확인 (a) [cite: 38]
                    raw_scores = [row['중간'].strip(), row['기말'].strip(), row['과제'].strip()]
                    
                    if not all(raw_scores): # 하나라도 빈 칸이 있으면
                        raise ValueError("결측값 존재")
                    
                    # (b) 계산: 가중 평균 및 등급 매기기 [cite: 39-49]
                    m, f_s, a = map(float, raw_scores)
                    avg = m * 0.3 + f_s * 0.5 + a * 0.2
                    
                    if avg >= 90: grade = "A"
                    elif avg >= 80: grade = "B"
                    elif avg >= 70: grade = "C"
                    else: grade = "F"
                    
                    scores_dict = {"중간": int(m), "기말": int(f_s), "과제": int(a)}
                    # (d) 성공 로그 기록 [cite: 70]
                    logging.info(f"{name}: 평균 {avg}, 등급 {grade}")
                    
                except (ValueError, KeyError, TypeError):
                    # (a) 결측값인 경우 None 처리 
                    m = int(row['중간']) if row.get('중간') and row['중간'].strip() else None
                    f_s = int(row['기말']) if row.get('기말') and row['기말'].strip() else None
                    a = int(row['과제']) if row.get('과제') and row['과제'].strip() else None
                    avg = None
                    grade = None
                    scores_dict = {"중간": m, "기말": f_s, "과제": a}
                    # (d) 결측값 알림 로그 [cite: 70]
                    logging.info(f"{name}: 결측값이 있어 계산되지 않았습니다.")

                # (c) 결과 리스트 추가 [cite: 50-64]
                results.append({
                    "이름": name,
                    "학번": sid,
                    "점수": scores_dict,
                    "평균": avg,
                    "등급": grade
                })
                processed_count += 1

        # (c) 쓰기: JSON 저장 (한글 보존, 들여쓰기) [cite: 50]
        with open(json_path, "w", encoding="utf-8") as jf:
            json.dump(results, jf, ensure_ascii=False, indent=4)
            
        return processed_count

    # (d) 예외 처리 [cite: 68-69]
    except FileNotFoundError:
        logging.warning(f"파일이 없습니다: {csv_path}")
        return 0
    except UnicodeDecodeError:
        logging.error(f"인코딩 오류가 발생했습니다: {csv_path}")
        return 0

# 함수 호출
make_report("scores.csv", "report.json")
