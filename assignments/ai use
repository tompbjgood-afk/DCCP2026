import csv
import json
import logging

def make_report(csv_path: str, json_path: str) -> int:
    results = []
    try:
        # utf-8-sig를 쓰면 보이지 않는 공백/BOM 문제를 해결해줍니다.
        with open(csv_path, "r", encoding="utf-8-sig") as f:
            reader = csv.DictReader(f, skipinitialspace=True)
            
            # 헤더의 공백을 한 번 더 강제로 제거합니다.
            reader.fieldnames = [name.strip() for name in reader.fieldnames]
            
            for row in reader:
                # 여기서 데이터가 출력되는지 확인하세요!
                print(f"읽은 데이터: {row}") 
                
                name = row['이름'].strip()
                sid = row['학번'].strip()
                
                # ... 성적 계산 로직 (중략) ...
                
                # 리스트에 추가 (반드시 이 들여쓰기 위치여야 합니다!)
                results.append({
                    "이름": name,
                    "학번": sid,
                    # ... 나머지 필드 추가 ...
                })

        with open(json_path, "w", encoding="utf-8") as jf:
            json.dump(results, jf, ensure_ascii=False, indent=4)
        
        return len(results)

    except Exception as e:
        print(f"오류 발생: {e}")
        return 0

# 호출부
make_report("scores.csv", "report.json")
