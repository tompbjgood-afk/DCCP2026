logging.basicConfig(level=logging.INFO, format='%(levelname)s: %(message)s')

def make_report(csv_path: str, json_path: str) -> int:
    results = []
    
    try:
        with open(csv_path, "r", encoding="utf-8-sig") as f:
            reader = csv.DictReader(f)
            
            # [중요] 모든 열 이름의 앞뒤 공백을 강제로 제거합니다.
            reader.fieldnames = [name.strip() for name in reader.fieldnames]
            print(f"디버깅 - 인식된 헤더: {reader.fieldnames}")
            
            for row in reader:
                # 데이터 한 줄을 읽을 때마다 출력해서 확인
                print(f"디버깅 - 읽은 데이터: {row}")
                
                # 1. 이름과 학번 가져오기
                name = row['이름'].strip()
                sid = row['학번'].strip()
                
                # 2. 점수 계산 및 결측값 처리 [cite: 38-49]
                try:
                    # 칸이 하나라도 비어있으면 ValueError 유도
                    if not (row['중간'].strip() and row['기말'].strip() and row['과제'].strip()):
                        raise ValueError
                    
                    m = int(row['중간'])
                    f_s = int(row['기말'])
                    a = int(row['과제'])
                    
                    # 가중 평균 계산 [cite: 39]
                    avg = m * 0.3 + f_s * 0.5 + a * 0.2
                    
                    # 등급 판정 [cite: 42-49]
                    if avg >= 90: grade = "A"
                    elif avg >= 80: grade = "B"
                    elif avg >= 70: grade = "C"
                    else: grade = "F"
                    
                except (ValueError, KeyError):
                    # 결측값이 있는 학생 처리 [cite: 38, 62-64]
                    m = int(row['중간']) if row.get('중간') else None
                    f_s = int(row['기말']) if row.get('기말') else None
                    a = int(row['과제']) if row.get('과제') else None
                    avg = None
                    grade = None

                # 3. 리스트에 추가 (반드시 이 들여쓰기 위치여야 합니다!)
                results.append({
                    "이름": name,
                    "학번": sid,
                    "점수": {"중간": m, "기말": f_s, "과제": a},
                    "평균": avg,
                    "등급": grade
                })
                
                # 로그 출력 [cite: 70]
                if avg is not None:
                    logging.info(f"{name}: {avg}, {grade}")
                else:
                    logging.info(f"{name}: 결측값이 있어 계산되지 않았습니다.")

        # 4. JSON 저장 (옵션 필수: 한글 보존, 들여쓰기) [cite: 50]
        with open(json_path, "w", encoding="utf-8") as jf:
            json.dump(results, jf, ensure_ascii=False, indent=4)
            
        return len(results)

    except FileNotFoundError: # [cite: 68]
        logging.warning(f"파일이 없습니다: {csv_path}")
        return 0
    except UnicodeDecodeError: # [cite: 69]
        logging.error(f"인코딩 오류: {csv_path}")
        return 0

