import csv
import json
import logging

# 로그 설정 [cite: 67]
logging.basicConfig(level=logging.INFO, format='%(levelname)s: %(message)s')

def make_report(csv_path: str, json_path: str) -> int:
    results = []
    
    try:
        # utf-8-sig는 보이지 않는 유령 문자(BOM)를 제거해줍니다.
        with open(csv_path, "r", encoding="utf-8-sig") as f:
            reader = csv.DictReader(f)
            
            # 혹시 모를 헤더 공백 강제 제거
            reader.fieldnames = [name.strip() for name in reader.fieldnames]
            
            for row in reader:
                name = row['이름'].strip()
                sid = row['학번'].strip()
                
                # 결측값 체크 로직 [cite: 38]
                try:
                    # 중간, 기말, 과제 중 하나라도 비어있으면 오류 발생시킴
                    if not (row['중간'] and row['기말'] and row['과제']):
                        raise ValueError
                    
                    mid = int(row['중간'])
                    fin = int(row['기말'])
                    ass = int(row['과제'])
                    
                    # 가중 평균 계산 (30%, 50%, 20%) [cite: 39]
                    avg = mid * 0.3 + fin * 0.5 + ass * 0.2
                    
                    # 등급 판정 [cite: 42-49]
                    if avg >= 90: grade = "A"
                    elif avg >= 80: grade = "B"
                    elif avg >= 70: grade = "C"
                    else: grade = "F"
                    
                except (ValueError, KeyError):
                    # 빈 칸이 있는 경우 None(null) 처리 [cite: 38, 63-64]
                    mid = int(row['중간']) if row.get('중간') else None
                    fin = int(row['기말']) if row.get('기말') else None
                    ass = int(row['과제']) if row.get('과제') else None
                    avg = None
                    grade = None

                # 데이터 리스트에 담기
                results.append({
                    "이름": name,
                    "학번": sid,
                    "점수": {"중간": mid, "기말": fin, "과제": ass},
                    "평균": avg,
                    "등급": grade
                })
                
                # 로그 기록 [cite: 70]
                logging.info(f"{name}: {avg}, {grade}")

        # JSON 파일 쓰기 (들여쓰기 및 한글 보존 옵션) [cite: 50]
        with open(json_path, "w", encoding="utf-8") as jf:
            json.dump(results, jf, ensure_ascii=False, indent=4)
            
        return len(results)

    except FileNotFoundError: # [cite: 68]
        logging.warning(f"파일이 없습니다: {csv_path}")
        return 0
    except UnicodeDecodeError: # [cite: 69]
        logging.error(f"인코딩 오류: {csv_path}")
        return 0

# 호출
make_report("scores.csv", "report.json")
