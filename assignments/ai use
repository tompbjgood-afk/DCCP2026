import logging

# (a) 사용자 정의 예외 클래스 정의
class InvalidJamoError(ValueError):
    """한글 자음이나 모음이 아닌 문자가 들어왔을 때 발생하는 예외"""
    pass

# (b) 자모 분류 함수 구현
def classify_jamo(c: str) -> str:
    # 인자가 str 타입이 아니면 TypeError 발생 [cite: 77]
    if not isinstance(c, str):
        raise TypeError(f"문자열이 아닙니다: {type(c).__name__}")
    
    # 길이가 1이 아니면 ValueError 발생 [cite: 78]
    if len(c) != 1:
        raise ValueError(f"한 글자만 입력해야 합니다: '{c}'")
    
    code = ord(c)
    
    # 한글 자음 범위: U+3131 ~ U+314E [cite: 79]
    if 0x3131 <= code <= 0x314E:
        return "자음"
    # 한글 모음 범위: U+314F ~ U+3163 [cite: 80]
    elif 0x314F <= code <= 0x3163:
        return "모음"
    # 그 외의 경우 InvalidJamoError 발생 [cite: 81]
    else:
        raise InvalidJamoError(f"유효한 한글 자모가 아닙니다: '{c}'")

# (c) 입력 리스트 처리 [cite: 82-86]
inputs = ["ㄱ", "ㅏ", "ㅎ", "ㅣ", "AB", 5, "!", " ", ""]

for item in inputs:
    try:
        result = classify_jamo(item)
        print(result)
    except TypeError as e:
        print(f"[TypeError] {e}")
    except InvalidJamoError as e:
        print(f"[InvalidJamoError] {e}")
    except ValueError as e:
        print(f"[ValueError] {e}")
