        "num": num,
        "start": start,
        "type1": "word"
    }
    
    # 사양서 조건: timeout=10 명시
    r = requests.get(url, params=params, timeout=10)
    
    # 사양서 조건: HTTP 오류 검사
    r.raise_for_status()
    
    # 사양서 조건: r.json() 반환
