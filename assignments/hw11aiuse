import os
import requests
import json
from dotenv import load_dotenv

# .env 로드 (이미 잘 작동하는 부분)
load_dotenv()
KEY = os.environ.get("KOREAN_DICT_KEY")

def search_word(q: str, num: int = 10, start: int = 1) -> dict:
    url = "https://opendict.korean.go.kr/api/search"
    
    # 국립국어원 규격에 맞게 파라미터를 완벽하게 보정합니다.
    r = requests.get(url, params={
        "key": KEY, 
        "query": q, 
        "req_type": "JSON",   # 🎯 반드시 대문자 "JSON"
        "method": "exact",    # 🎯 [필수] 검색 방식 추가 (exact: 일치 단어 찾기)
        "num": num, 
        "start": start, 
        "type1": "word"
    }, timeout=10)
    
    r.raise_for_status()
    return r.json()
