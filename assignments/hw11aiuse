import requests

REAL_KEY = "74B77327790EFCEA20E69119C48D4B13"
url = "https://opendict.korean.go.kr/api/search"

# 국립국어원 규격에 맞춘 필수 파라미터 세트입니다.
params = {
    "key": REAL_KEY,
    "query": "김치",
    "req_type": "JSON",  # 대문자 유지
