import os
import requests
from dotenv import load_dotenv

# 🎯 [핵심] 현재 실행 중인 주피터 노트북 파일의 '진짜 폴더 경로'를 구합니다.
current_dir = os.path.dirname(os.path.abspath('__file__'))
env_path = os.path.join(current_dir, '.env')

# 구한 경로로 .env 파일을 강제 로드합니다.
load_dotenv(dotenv_path=env_path)

KEY = os.environ.get("KOREAN_DICT_KEY")

# 🔍 디버깅용 출력 (이제 무조건 키가 찍혀야 합니다!)
print("실제 탐색한 .env 경로:", env_path)
print("최종 불러온 API 키:", KEY)

def search_word(q: str, num: int = 10, start: int = 1) -> dict:
    url = "https://opendict.korean.go.kr/api/search"
    r = requests.get(url, params={
        "key": KEY, 
        "query": q, 
        "req_type": "json", 
        "num": num, 
        "start": start, 
        "type1": "word"
    }, timeout=10)
    r.raise_for_status()
    return r.json()
